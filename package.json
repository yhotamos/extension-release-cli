{
  "name": "ext-release-cli",
  "version": "0.0.1",
  "description": "CLI tool to build, package, and publish Chrome extensions to the Chrome Web Store.",
  "type": "module",
  "bin": {
    "exr": "dist/cli.js"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "build": "npm run lint && npm run typecheck && tsup",
    "build:dev": "tsup --sourcemap",
    "watch": "tsup --watch",
    "test": "vitest"
  },
  "keywords": [
    "cli",
    "chrome-extension",
    "webstore",
    "release",
    "automation"
  ],
  "files": [
    "dist"
  ],
  "author": "yhotta240 <yhotta240@gmail.com> (https://github.com/yhotta240)",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "kleur": "^4.1.5",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "eslint": "^10.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
